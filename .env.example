# Supabase
# Get these from your project at https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Add authorised redirect URI: https://your-domain.com/api/auth/callback/google
# Enable: Google Drive API, Gmail API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth v5 (next-auth@beta)
# Generate secret with: openssl rand -base64 32
# AUTH_SECRET is the primary env var name for next-auth v5
AUTH_SECRET=your-auth-secret
NEXTAUTH_URL=https://your-domain.com
